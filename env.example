# Copy this file to .env and fill in values.
# (Named env.example rather than .env.example because the latter was blocked
# by sandbox permissions when I scaffolded the project.)

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Vapi
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_ASSISTANT_ID=
VAPI_PHONE_SIP=

# OpenAI (for post-call summaries + chat widget)
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini

# Dashboard/admin API token (random long string, required for /api/calls etc.)
ADMIN_TOKEN=

# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Public base URL of this server (for Twilio signature verification in dev).
# Set to your ngrok HTTPS URL, e.g. https://abc123.ngrok-free.app
PUBLIC_BASE_URL=

# Comma-separated CORS allowlist. Empty allows all origins (useful for local dev).
# Example: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com
CORS_ALLOWED_ORIGINS=

# Rate limiting (per IP). Tune for your traffic profile.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_CHAT_MAX_REQUESTS=30
RATE_LIMIT_ADMIN_MAX_REQUESTS=60
RATE_LIMIT_WEBHOOK_MAX_REQUESTS=240
